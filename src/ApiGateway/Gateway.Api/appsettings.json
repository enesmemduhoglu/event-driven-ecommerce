{
  "Seq": {
    "ServerUrl": "http://localhost:5341"
  },
  "RateLimiting": {
    "PermitLimit": 100,
    "WindowSeconds": 10
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:5173" ]
  },
  "HealthChecksUI": {
    "HealthChecks": [
      { "Name": "gateway-api", "Uri": "http://localhost:5000/health" },
      { "Name": "identity-api", "Uri": "http://localhost:5001/health" },
      { "Name": "catalog-api", "Uri": "http://localhost:5002/health" },
      { "Name": "search-api", "Uri": "http://localhost:5003/health" },
      { "Name": "basket-api", "Uri": "http://localhost:5004/health" },
      { "Name": "ordering-api", "Uri": "http://localhost:5005/health" },
      { "Name": "inventory-api", "Uri": "http://localhost:5006/health" },
      { "Name": "payment-api", "Uri": "http://localhost:5007/health" },
      { "Name": "notification-api", "Uri": "http://localhost:5008/health" }
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "identity-auth": {
        "ClusterId": "identity",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },
      "identity-discovery": {
        "ClusterId": "identity",
        "Match": { "Path": "/.well-known/{**catch-all}" }
      },
      "catalog-products": {
        "ClusterId": "catalog",
        "Match": { "Path": "/api/products/{**catch-all}" }
      },
      "catalog-categories": {
        "ClusterId": "catalog",
        "Match": { "Path": "/api/categories/{**catch-all}" }
      },
      "search": {
        "ClusterId": "search",
        "Match": { "Path": "/api/search/{**catch-all}" }
      },
      "basket": {
        "ClusterId": "basket",
        "Match": { "Path": "/api/basket/{**catch-all}" }
      },
      "ordering": {
        "ClusterId": "ordering",
        "Match": { "Path": "/api/orders/{**catch-all}" }
      },
      "inventory": {
        "ClusterId": "inventory",
        "Match": { "Path": "/api/inventory/{**catch-all}" }
      },
      "notification-hubs": {
        "ClusterId": "notification",
        "Match": { "Path": "/hubs/{**catch-all}" }
      }
    },
    "Clusters": {
      "identity": {
        "Destinations": { "d1": { "Address": "http://localhost:5001/" } }
      },
      "catalog": {
        "Destinations": { "d1": { "Address": "http://localhost:5002/" } }
      },
      "search": {
        "Destinations": { "d1": { "Address": "http://localhost:5003/" } }
      },
      "basket": {
        "Destinations": { "d1": { "Address": "http://localhost:5004/" } }
      },
      "ordering": {
        "Destinations": { "d1": { "Address": "http://localhost:5005/" } }
      },
      "inventory": {
        "Destinations": { "d1": { "Address": "http://localhost:5006/" } }
      },
      "notification": {
        "Destinations": { "d1": { "Address": "http://localhost:5008/" } }
      }
    }
  },
  "AllowedHosts": "*"
}
